projection;
strict ( 2 );
use draft;

define behavior for ZC_HEADER alias PurchaseOrder
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Items { create; with draft; }
}

define behavior for ZC_ITEMSPO alias PurchaseOrderItem
{
  use update;
  use delete;

  use association _PurchaseOrder { with draft; }
}
